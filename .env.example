# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site — required
NEXT_PUBLIC_SITE_URL=

# Cloudflare Stream — required for video uploads via API (not runtime)
# At runtime the app references videos by UID via the iframe URL only.
# This account ID is needed if/when uploading videos programmatically
# rather than through the Cloudflare dashboard.
# Server-side only — never prefix with NEXT_PUBLIC_.
CLOUDFLARE_ACCOUNT_ID=
